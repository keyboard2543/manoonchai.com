---
// Although this file imports `sydiime`,
// many parts of this page depend on SyDiIME but are not
// considered part of the SyDiIME codebase.
//
// They are independent components of this project and
// are distributed under the MIT License.
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { layoutsData } from '../scripts/sydiime-layouts.js';

const metadata = {
  title: 'Try Manoonchai',
};

const pc = [
  'Backquote',
  'Digit1',
  'Digit2',
  'Digit3',
  'Digit4',
  'Digit5',
  'Digit6',
  'Digit7',
  'Digit8',
  'Digit9',
  'Digit0',
  'Minus',
  'Equal',
  'Backspace',
  'Tab',
  'KeyQ',
  'KeyW',
  'KeyE',
  'KeyR',
  'KeyT',
  'KeyY',
  'KeyU',
  'KeyI',
  'KeyO',
  'KeyP',
  'BracketLeft',
  'BracketRight',
  'Backslash',
  'CapsLock',
  'KeyA',
  'KeyS',
  'KeyD',
  'KeyF',
  'KeyG',
  'KeyH',
  'KeyJ',
  'KeyK',
  'KeyL',
  'Semicolon',
  'Quote',
  'Enter',
  'ShiftLeft',
  'KeyZ',
  'KeyX',
  'KeyC',
  'KeyV',
  'KeyB',
  'KeyN',
  'KeyM',
  'Comma',
  'Period',
  'Slash',
  'ShiftRight',
  'btnF1',
  'seltrLays',
  'Space',
  'AltRight',
  'btnHide',
];

const iconKeys = {
  Tab: 'tabler:arrow-bar-to-right',
  Enter: 'tabler:corner-down-left',
  Backspace: 'tabler:backspace',
  ShiftLeft: 'tabler:arrow-big-up',
  ShiftRight: 'tabler:arrow-big-up',
  CapsLock: 'tabler:arrow-big-up-line',
  AltRight: 'tabler:trending-up-2',
};

const iconBtns = {
  btnF1: 'tabler:world',
  btnHide: 'tabler:keyboard-show',
};
---

<style is:global>
  :root {
    --sydiime-font-family:
      Sarabun, 'Hiragino Kaku Gothic Pro', 'Hiragino Sans', '游ゴシック',
      'Yu Gothic', 'メイリオ', 'Meiryo', 'ＭＳ Ｐゴシック', 'MS PGothic',
      'Noto Sans JP', 'Noto Sans CJK JP', 'IPAMonaPGothic',
      'IPA モナー Pゴシック', 'Chocolate Classical Sans', SF-Pro, Thonburi,
      Garuda, Tahoma, sans-serif;
  }
  #sydiime-textEditor,
  textarea {
    font-family: var(--sydiime-font-family);
  }
  #sydiime-fltCont {
    @apply fixed right-0 bottom-0 p-2 bg-gray-200 dark:bg-gray-900 rounded-lg z-20;
    box-shadow:
      rgba(66, 68, 90, 0.5) 0px 0px 1px 0px,
      rgba(0, 0, 0, 0.12) 0px 0px 2px,
      rgba(0, 0, 0, 0.14) 0px 4px 8px,
      rgba(255, 255, 255, 0.5) 0 0 0 1px inset,
      rgba(200, 200, 200, 0.5) 0 -1px 0 0 inset;
  }
  #sydiime-kbdvtCont {
    @apply mx-auto max-w-[860px] w-full z-20 fixed bottom-0 tall-sm:bottom-4 left-0 right-0;
    touch-action: manipulation;
    transition:
      transform 0.1s ease-out,
      max-width 0.1s ease-out,
      bottom 0.1s ease-out,
      right 0.1s ease-out,
      opacity 0.1s ease-out;
    &::before {
      content: ' ';
      @apply z-[-1] absolute inset-0 bg-gray-200 dark:bg-gray-900 rounded-[8px];
      /* @apply  md:bg-gray-200/50 md:backdrop-blur-md; หนักเครื่องเกินไป */
      box-shadow:
        rgba(66, 68, 90, 0.5) 0px 0px 1px 0px,
        rgba(0, 0, 0, 0.12) 0px 0px 2px,
        rgba(0, 0, 0, 0.14) 0px 4px 8px,
        rgba(255, 255, 255, 0.5) 0 0 0 1px inset,
        rgba(200, 200, 200, 0.5) 0 -1px 0 0 inset;
    }
  }
  #sydiime-kbd {
    @apply grid [grid-template-columns:repeat(58,1fr)] [grid-template-rows:repeat(10,1fr)] justify-center;
    @apply select-none mx-auto mb-0 p-[5px] sm:p-[8px] relative max-h-[50vh] h-[300px] gap-[3px] sm:gap-[8px];
  }

  .sydiime-key {
    @apply col-span-4 row-span-2 p-0 text-center border-0 cursor-pointer whitespace-nowrap flex justify-center items-center relative;
    @apply text-[26px] rounded-[6px];
    @apply bg-white dark:bg-slate-800 border-b border-gray-400 dark:border-gray-800;
    font-family: var(--sydiime-font-family);
    touch-action: manipulation;

    &.sydiime-active {
      @apply !bg-gray-300 dark:!bg-gray-700;
    }
  }

  .sydiime-text {
    @apply text-xl 2xl:text-base
         whitespace-nowrap
         absolute top-0
         p-0
         overflow-visible
         text-center
         min-w-[20%]
         h-[120%]
         mx-auto;

    &.sydiime-active {
      @apply text-current dark:text-white;
    }

    &.sydiime-mute {
      @apply text-neutral-300 dark:text-neutral-600;
    }

    &.sydiime-mute-s {
      @apply text-gray-500 dark:text-gray-400;
    }
  }

  .sydiime-t0 {
    right: 10%;
    top: 40%;
  }

  .sydiime-t1 {
    left: 20%;
    @apply text-gray-500 dark:text-gray-400;
  }

  .sydiime-t2 {
    right: 5%;
  }

  .sydiime-t3 {
    right: 30%;
  }
  .sydiime-t2,
  .sydiime-t3 {
    @apply text-neutral-300 dark:text-neutral-600;
  }

  /* Special keys */
  #sydiime-k-ShiftLeft,
  #sydiime-k-ShiftRight,
  #sydiime-k-Enter,
  #sydiime-k-Backspace,
  #sydiime-k-Tab,
  #sydiime-k-AltRight,
  #sydiime-k-CapsLock,
  #sydiime-btnF1,
  #sydiime-btnHide {
    @apply bg-gray-300 dark:bg-gray-600;
    &.sydiime-active {
      @apply !bg-gray-400 dark:!bg-gray-700;
    }
  }

  #sydiime-k-Tab {
    @apply col-span-6;
  }

  #sydiime-k-CapsLock {
    @apply col-span-7;
  }

  #sydiime-k-KeyF,
  #sydiime-k-KeyJ {
    @apply border-blue-500;
  }

  #sydiime-k-ShiftLeft {
    @apply col-span-9;
  }

  #sydiime-k-ShiftRight {
    @apply col-span-9;
  }

  #sydiime-k-Enter {
    @apply col-span-7;
  }

  #sydiime-k-Backspace {
    @apply col-span-6;
  }

  #sydiime-seltrLays {
    @apply bg-gray-300 dark:bg-gray-600;
    @apply text-xl 2xl:text-base pl-2;
    text-align: start;
    grid-column-start: span 13;
    grid-column-end: span 13;
  }

  #sydiime-k-Space {
    grid-column-start: 18;
    grid-column-end: span 20;
  }

  #sydiime-btnHide {
    grid-column-start: 55;
  }
</style>
<Layout metadata={metadata}>
  <div class="max-w-7xl mx-auto px-4">
    <div id="sydiime-textEditor" class="relative">
      <!-- Toolbar -->
      <div class="absolute right-4 top-4 flex items-center gap-2 z-10 bg-white/80 dark:bg-slate-900/80 backdrop-blur border border-gray-200 dark:border-gray-800 rounded-lg p-1 shadow-sm">
        <!-- Auto Switch Toggle -->
        <label class="flex items-center gap-1.5 text-xs text-gray-600 dark:text-gray-400 cursor-pointer border-r border-gray-200 dark:border-gray-800 pr-2 mr-1 select-none">
          <input type="checkbox" id="sydiime-auto-switch" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
          <span class="hidden md:inline">สลับแป้นพิมพ์ตามตั้งค่าเครื่อง</span>
          <span class="inline md:hidden">Auto</span>
        </label>

        <!-- Font Size Controls -->
        <div class="flex items-center border-r border-gray-200 dark:border-gray-800 pr-2 mr-1">
          <button id="sydiime-font-dec" class="p-1.5 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white rounded hover:bg-gray-100 dark:hover:bg-slate-800 transition" title="ลดขนาดตัวอักษร">
            <Icon name="tabler:text-size" class="w-4 h-4 inline" /><span class="text-xs font-bold">-</span>
          </button>
          <button id="sydiime-font-inc" class="p-1.5 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white rounded hover:bg-gray-100 dark:hover:bg-slate-800 transition" title="เพิ่มขนาดตัวอักษร">
            <Icon name="tabler:text-size" class="w-4 h-4 inline" /><span class="text-xs font-bold">+</span>
          </button>
        </div>
        
        <!-- Copy Button -->
        <button id="sydiime-btn-copy" class="flex items-center gap-1 px-2.5 py-1.5 text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white rounded hover:bg-gray-100 dark:hover:bg-slate-800 transition" title="คัดลอกข้อความ">
          <Icon name="tabler:copy" class="w-4 h-4" />
          <span id="sydiime-copy-text" class="hidden sm:inline">คัดลอก</span>
        </button>
        
        <!-- Clear Button -->
        <button id="sydiime-btn-clear" class="flex items-center gap-1 px-2.5 py-1.5 text-sm font-medium text-red-600 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 rounded hover:bg-red-50 dark:hover:bg-red-950/20 transition" title="ล้างข้อความ">
          <Icon name="tabler:trash" class="w-4 h-4" />
          <span class="hidden sm:inline">ล้าง</span>
        </button>
      </div>

      <textarea
        id="sydiime-textArea"
        class="w-full h-full min-h-screen text-xl pt-16 px-4 pb-16 focus:outline-none focus:none rounded-lg border border-gray-300 bg-orange-50 dark:bg-black dark:text-white"
        aria-label="text area"
        inputmode="none"
        placeholder="พิมพ์ตรงนี้ได้เลย! ตัวเลือกเปลี่ยนแป้นอยู่มุมซ้ายล่างของคีย์บอร์ดบนจอ กด Tab เพื่อสลับแป้นที่ใช้ล่าสุด..."
      ></textarea>

      <!-- Status Bar / Counters -->
      <div class="absolute left-4 bottom-4 text-xs text-gray-500 dark:text-gray-400 bg-white/80 dark:bg-slate-900/80 backdrop-blur px-2.5 py-1.5 rounded-md border border-gray-200 dark:border-gray-800 z-10">
        <span id="sydiime-char-count">0</span> ตัวอักษร
      </div>
    </div>
  </div>

  <div id="sydiime-kbdvtCont" class="">
    <div id="sydiime-kbd" class="sydiime-kbd">
      {
        pc.map(key =>
          key === 'seltrLays' ? (
            <select class="sydiime-key" id="sydiime-seltrLays">
              <option value="default">System</option>
              <option value="thai-mnc">มนูญชัย</option>
              <option value="thai-mnc-jis">มนูญชัย JIS</option>
              <option value="thai-tis">มอก. 820-2538</option>
              <option value="thai-ptj">ปัตตะโชติ</option>
            </select>
          ) : iconBtns[key] ? (
            <div class="sydiime-key" id={`sydiime-${key}`}>
              <Icon name={iconBtns[key]} />
            </div>
          ) : iconKeys[key] ? (
            <div class="sydiime-key" id={`sydiime-k-${key}`}>
              <Icon name={iconKeys[key]} />
            </div>
          ) : (
            <div class="sydiime-key" id={`sydiime-k-${key}`}>
              <div class="sydiime-text sydiime-t2">
                {layoutsData['thai-mnc'].main_keys[key]?.[2]}
              </div>
              <div class="sydiime-text sydiime-t3">
                {layoutsData['thai-mnc'].main_keys[key]?.[3]}
              </div>
              <div class="sydiime-text sydiime-t0">
                {layoutsData['thai-mnc'].main_keys[key]?.[0]}
              </div>
              <div class="sydiime-text sydiime-t1">
                {layoutsData['thai-mnc'].main_keys[key]?.[1]}
              </div>
            </div>
          ),
        )
      }
    </div>
  </div>
  <div id="sydiime-fltCont" class="hidden">
    <button id="sydiime-btnShow" class="text-lg p-1"
      ><Icon name="tabler:keyboard-hide" class="w-6 h-6 inline-block" /></button
    >
  </div>
  <Fragment slot="footer"></Fragment>
</Layout>

<script>
  import SyDiIME from '../scripts/sydiime.js';

  function initUIControls() {
    const textarea = document.getElementById('sydiime-textArea') as HTMLTextAreaElement;
    const btnCopy = document.getElementById('sydiime-btn-copy');
    const btnClear = document.getElementById('sydiime-btn-clear');
    const btnFontInc = document.getElementById('sydiime-font-inc');
    const btnFontDec = document.getElementById('sydiime-font-dec');
    const charCountEl = document.getElementById('sydiime-char-count');
    const copyTextEl = document.getElementById('sydiime-copy-text');

    if (textarea) {
      // 1. Font Size Adjuster
      let currentFontSize = 20; // default 20px
      
      const savedFontSize = localStorage.getItem('sydiime-fontSize');
      if (savedFontSize) {
        currentFontSize = parseInt(savedFontSize, 10);
        textarea.style.fontSize = `${currentFontSize}px`;
      }

      btnFontInc?.addEventListener('click', () => {
        if (currentFontSize < 40) {
          currentFontSize += 2;
          textarea.style.fontSize = `${currentFontSize}px`;
          localStorage.setItem('sydiime-fontSize', currentFontSize.toString());
        }
      });

      btnFontDec?.addEventListener('click', () => {
        if (currentFontSize > 12) {
          currentFontSize -= 2;
          textarea.style.fontSize = `${currentFontSize}px`;
          localStorage.setItem('sydiime-fontSize', currentFontSize.toString());
        }
      });

      // 2. Character & Word Counters
      const updateCounters = () => {
        const text = textarea.value;
        const charCount = text.length;
        
        if (charCountEl) charCountEl.textContent = charCount.toString();
      };

      textarea.addEventListener('input', updateCounters);
      document.addEventListener('keyup', updateCounters);
      document.addEventListener('pointerup', updateCounters);
      
      // Initialize counters
      updateCounters();

      // 3. Copy to Clipboard
      btnCopy?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(textarea.value);
          if (copyTextEl) {
            copyTextEl.textContent = 'คัดลอกแล้ว!';
            setTimeout(() => {
              copyTextEl.textContent = 'คัดลอก';
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });

      // 4. Clear Text
      btnClear?.addEventListener('click', () => {
        if (confirm('คุณต้องการล้างข้อความทั้งหมดใช่หรือไม่?')) {
          textarea.value = '';
          localStorage.removeItem('savedText');
          updateCounters();
          textarea.focus();
        }
      });
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (location.pathname === '/try') {
      SyDiIME.init();
      initUIControls();
    }
  });
  document.addEventListener('astro:before-swap', () => {
    if (location.pathname === '/try') {
      SyDiIME.destroy();
    }
  });
</script>
